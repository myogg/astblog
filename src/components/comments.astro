---
const API_URL = 'https://comment-api.xxjss.workers.dev';
const pathname = Astro.url.pathname;
---

<div class="w-full max-w-3xl mx-auto px-7 lg:px-0 mb-20 pt-8 border-t border-neutral-200 dark:border-neutral-800">
  <h3 class="text-xl font-semibold mb-6 text-neutral-900 dark:text-neutral-100">评论</h3>

  <form id="comment-form" class="mb-8 space-y-4">
    <div class="grid grid-cols-2 gap-4">
      <input type="text" id="name" placeholder="昵称（可选）" class="px-4 py-2 border rounded-lg dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-100" />
      <input type="email" id="email" placeholder="邮箱（可选）" class="px-4 py-2 border rounded-lg dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-100" />
    </div>
    <textarea id="content" placeholder="写下你的评论..." rows="4" required class="w-full px-4 py-2 border rounded-lg dark:bg-neutral-900 dark:border-neutral-700 dark:text-neutral-100"></textarea>
    <button type="submit" class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">发表评论</button>
  </form>

  <div id="comments-list" class="space-y-4"></div>
</div>

<script define:vars={{ API_URL, pathname }}>
  console.log('评论脚本已加载', { API_URL, pathname });

  const form = document.getElementById('comment-form');
  const list = document.getElementById('comments-list');

  console.log('表单元素:', form);
  console.log('列表元素:', list);

  async function loadComments() {
    console.log('开始加载评论...');
    console.log('当前路径:', pathname);
    try {
      // 确保路径编码一致
      const encodedPath = encodeURI(pathname);
      console.log('编码后路径:', encodedPath);

      const res = await fetch(`${API_URL}/comments?page=${encodedPath}`);
      const comments = await res.json();
      console.log('收到评论:', comments);

      if (comments.length === 0) {
        list.innerHTML = '<p class="text-neutral-500 dark:text-neutral-400">暂无评论</p>';
        return;
      }

      list.innerHTML = comments.map(c => `
        <div class="p-4 border rounded-lg dark:border-neutral-700">
          <div class="flex items-center gap-2 mb-2">
            <span class="font-medium text-neutral-900 dark:text-neutral-100">${c.name || '匿名'}</span>
            <span class="text-sm text-neutral-500">${new Date(c.created_at).toLocaleString('zh-CN')}</span>
          </div>
          <p class="text-neutral-700 dark:text-neutral-300">${c.content}</p>
        </div>
      `).join('');
    } catch (err) {
      console.error('加载评论失败:', err);
      list.innerHTML = '<p class="text-red-500">加载评论失败</p>';
    }
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    console.log('表单提交事件触发');

    const name = document.getElementById('name').value;
    const email = document.getElementById('email').value;
    const content = document.getElementById('content').value;

    console.log('提交数据:', { page: pathname, name, email, content });

    try {
      const res = await fetch(`${API_URL}/comments`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ page: pathname, name, email, content })
      });

      console.log('POST 响应:', res.status);

      if (res.ok) {
        form.reset();
        await loadComments();
      } else {
        alert('发表评论失败');
      }
    } catch (err) {
      console.error('发表评论失败:', err);
      alert('发表评论失败');
    }
  });

  loadComments();
</script>
